<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Material Design 3 Theme – Transpent Green -->
    <style name="AppTheme" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary: Transpent teal-green -->
        <item name="colorPrimary">#1E7C5A</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorPrimaryContainer">#B7F0D9</item>
        <item name="colorOnPrimaryContainer">#00201A</item>
        <!-- Secondary -->
        <item name="colorSecondary">#4E6359</item>
        <item name="colorOnSecondary">#FFFFFF</item>
